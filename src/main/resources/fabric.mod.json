{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "Toggle, hide, and style nametags in-game.",
  "authors": [
    "Greek"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/hidetags",
    "sources": "https://github.com/Greek/ToggleNametags",
    "issues": "https://github.com/Greek/ToggleNametags/issues"
  },
  "license": "CC0-1.0",
  "icon": "assets/togglenametags/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "sh.ndy.ToggleNametagsClient"
    ],
    "modmenu": [
      "sh.ndy.ToggleNametagsModMenu"
    ]
  },
  "mixins": [
    "togglenametags.mixins.json",
    {
      "config": "togglenametags.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.17",
    "minecraft": "${minecraft}"
  },
  "suggests": {
    "mod-menu": "*"
  }
}